# Base URL of the OpenBundestag JSON API (api/main.py).
# Local dev:  http://127.0.0.1:8000  (uv run uvicorn api.main:app --port 8000)
# Production: the HF Space URL, e.g. https://<user>-openbundestag-api.hf.space
# Vite exposes only VITE_-prefixed vars to the client (import.meta.env.VITE_API_BASE).
VITE_API_BASE=http://127.0.0.1:8000
